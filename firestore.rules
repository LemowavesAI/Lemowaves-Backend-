rules_version = '2';

// ══════════════════════════════════════════════════════════════════
//  LEMOWAVES AI — FIRESTORE SECURITY RULES
//
//  SECURITY MODEL:
//  • Users can read their own data
//  • Users CANNOT write premium, planType, premiumExpiry — ever
//  • Only backend (Admin SDK) can write those fields
//  • Orders collection is backend-only (no client read/write)
//  • Usage logs are backend-only
// ══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS collection ──
    match /users/{userId} {

      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can write ONLY non-sensitive fields (display name, preferences)
      // CRITICAL: Premium fields are BLOCKED from client writes
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !("premium" in request.resource.data)
        && !("planType" in request.resource.data)
        && !("premiumExpiry" in request.resource.data)
        && !("uid" in request.resource.data);

      // No one else can read or write
      allow read, write: if false;
    }

    // ── ORDERS collection — backend only ──
    match /orders/{orderId} {
      // Clients cannot read or write orders at all
      // Only Firebase Admin SDK (backend) can access this
      allow read, write: if false;
    }

    // ── USAGE logs — backend only ──
    match /usage/{logId} {
      allow read, write: if false;
    }

    // ── Default: deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
